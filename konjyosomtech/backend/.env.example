# Konjyosom Tech Solutions - Environment Variables (Production)
# Copy this file to .env and fill in your real values
# The .env file is in .gitignore and will NOT be pushed to GitHub

# ==============================================
# REQUIRED
# ==============================================

# MongoDB Atlas Connection URI
# Get from: https://cloud.mongodb.com → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://Abhijit:Abhijit2@cluster0.vw23lfu.mongodb.net/konjyosom?retryWrites=true&w=majority

# JWT Secret - generate a strong random string (32+ characters)
# Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-jwt-secret-here

# ==============================================
# EMAIL (Resend - Free 3,000 emails/month)
# ==============================================
# 1. Go to https://resend.com and sign up (free)
# 2. Get your API key from the dashboard
# 3. Add it below
RESEND_API_KEY=re_BUk2N7NP_4ggN5tSp7qiMFPod9JGa4xDT

# ==============================================
# CORS & URLs
# ==============================================
# Your deployed frontend URL (on Vercel or Render)
FRONTEND_URL=https://konjyosom-website-1.onrender.com

# ==============================================
# ADMIN CREDENTIALS (auto-seed on first startup)
# ==============================================
ADMIN_EMAIL=admin@konjyosom.com
ADMIN_PASSWORD=Abhijit@2

# ==============================================
